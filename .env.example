# ============================================================
# UMOM - ADHD Coaching App Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

PORT=3000
NODE_ENV=development

# Anthropic (Claude)
# Get your key at: https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5

# Notion
# Get your integration token at: https://www.notion.so/my-integrations
# See docs/notion-setup.md for step-by-step database creation
NOTION_API_KEY=secret_...

# Notion Database IDs
# Each ID is the 32-char string in the database URL: notion.so/.../<DATABASE_ID>?v=...
NOTION_DB_CHECKINS=       # Daily check-in entries (mood, energy, focus)
NOTION_DB_TASKS=          # Task & habit tracker
NOTION_DB_JOURNAL=        # Cognitive reframing journal entries
NOTION_DB_REPORTS=        # Weekly/monthly report archives
NOTION_DB_CYCLE_LOGS=     # Menstrual cycle tracking data

# Brain dump web page — a secret passphrase to protect /brain-dump?key=SECRET (optional)
BRAIN_DUMP_KEY=

# Optional Notion databases
NOTION_DB_CALENDAR_EVENTS=  # Calendar / appointments (optional)
NOTION_DB_INBOX=             # "What's on Your Mind?" — type dumps in Notion, processed within 10s (optional)

# SQLite (local conversation history)
SQLITE_PATH=data/umom.db
